# ── Groq API (free) ──────────────────────────────────────────
# Get from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Supabase (free) ──────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── NOTE: No extra auth env vars needed! ──────────────────────
# Supabase Auth (Google OAuth) is configured inside Supabase Dashboard:
# Authentication → Providers → Google → Enable
# Add your Google OAuth credentials there directly.
# The redirect URL to add in Google Console and Supabase:
# https://your-project.supabase.co/auth/v1/callback
